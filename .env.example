# Copy to your config directory as .env (see README for location).
# Fill in the values you need.
# A local .env in this directory can override for testing.

# Required for: fpl preview --save --scout
PERPLEXITY_API_KEY=your-api-key-here

# Required for: fpl review league table (football-data.org)
FOOTBALL_DATA_API_KEY=your-api-key-here

# Required for: fpl review --save --summarise
ANTHROPIC_API_KEY=your-api-key-here

# FPL credentials for authenticated features (sell prices, transfers page)
# Required for: fpl squad sell-prices
# Prefer: fpl credentials set (stores in system keyring - not committed to git)
FPL_EMAIL=your-fpl-email@example.com
FPL_PASSWORD=your-fpl-password
